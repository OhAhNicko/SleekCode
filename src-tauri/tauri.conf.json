{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EzyDev",
  "version": "0.1.0",
  "identifier": "com.ezydev.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EzyDev",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "shadow": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://localhost:* ws://localhost:* wss://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
