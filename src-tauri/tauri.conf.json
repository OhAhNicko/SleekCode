{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MADE",
  "version": "0.1.64",
  "identifier": "com.made.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MADE",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "backgroundColor": "#0d1117"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' http: https: ws://localhost:* wss://localhost:*; frame-src http://localhost:* http://127.0.0.1:* https: data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": "all",
    "publisher": "MADE",
    "copyright": "Copyright 2025 MADE",
    "shortDescription": "AI Terminal Workspace",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/header.bmp",
        "sidebarImage": "installer-assets/sidebar.bmp",
        "displayLanguageSelector": false,
        "compression": "lzma"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5MEVENzdCNkJDNkMwMTIKUldRU3dNWnJlOWNPT1Zvak5mM1VoR0w3WDhOOU55WVpaeW9VcjdIbXlMcDRFL01OdmVaYzA0dzUK",
      "endpoints": [
        "https://github.com/OhAhNicko/SleekCode/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
